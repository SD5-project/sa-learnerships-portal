{
  "name": "sa-learnerships-portal",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "start": "node backend/app.js",
    "dev": "nodemon backend/app.js",
    "seed:nqf": "node backend/seedNQF.js",
    "test": "mocha tests/control-access.test.js && jest --testPathPattern=__tests__",
    "test:mocha": "mocha tests/control-access.test.js",
    "test:jest": "jest --testPathPattern=__tests__",
    "test:coverage": "jest --coverage --testPathPattern=__tests__",
    "test:watch": "jest --watchAll"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/jest.setup.js"],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "lcov",
      "text"
    ],
    "collectCoverageFrom": [
  "backend/routes/*Routes.js",
  "backend/access-logic.js",
  "!backend/routes/validationRoutes.js",
   "!backend/routes/opportunityRoutes.js"
]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Swag-png/sa-learnerships-portal.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Swag-png/sa-learnerships-portal/issues"
  },
  "homepage": "https://github.com/Swag-png/sa-learnerships-portal#readme",
  "devDependencies": {
    "jest": "^29.0.0",
    "mocha": "^11.3.0",
    "supertest": "^6.3.4"
  },
  "dependencies": {
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.8.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^3.0.0",
    "nodemailer": "^6.9.0",
    "nodemon": "^3.1.14"
  }
}