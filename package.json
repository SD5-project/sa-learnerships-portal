{
  "name": "sa-learnerships-portal",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "start":         "node backend/app.js",
    "test":          "mocha tests/control-access.test.js && jest --testPathPattern=__tests__",
    "test:mocha":    "mocha tests/control-access.test.js",
    "test:jest":     "jest --testPathPattern=__tests__",
    "test:coverage": "jest --testPathPattern=__tests__ --coverage --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverage": false,
    "collectCoverageFrom": [
      "backend/app.js",
      "backend/auth.js",
      "backend/access-logic.js"
    ],
    "coverageReporters": [
      "lcov",
      "text",
      "text-summary"
    ],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "lines": 10
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Swag-png/sa-learnerships-portal.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Swag-png/sa-learnerships-portal/issues"
  },
  "homepage": "https://github.com/Swag-png/sa-learnerships-portal#readme",
  "devDependencies": {
    "jest": "^29.0.0",
    "mocha": "^11.3.0",
    "supertest": "^6.3.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^5.2.1",
    "firebase-admin": "^13.8.0",
    "node-cron": "^3.0.0",
    "nodemailer": "^6.9.0",
    "nodemon": "^3.1.14"
  }
}